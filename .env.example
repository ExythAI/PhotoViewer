# Environment variables for PhotoViewer
# Copy this to .env and fill in your credentials

# SMB/CIFS credentials for \\winnfs\FamilyPhotos
SMB_USERNAME=your_username
SMB_PASSWORD=your_password

# Scanner interval in minutes (default: 60)
SCAN_INTERVAL=60

# JWT signing key (change in production!)
JWT_KEY=PhotoViewerSuperSecretDefaultKey2026
